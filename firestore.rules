rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Usuarios ───────────────────────────────────────
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer perfiles (necesario para búsqueda y avatares)
      allow read: if request.auth != null;
      // El propio usuario puede crear su perfil
      allow create: if request.auth != null && request.auth.uid == userId;
      // El propio usuario puede actualizar cualquier campo.
      // Escritura cruzada (otro usuario): solo se permite añadir o eliminar el propio UID
      // del campo 'friends'.  Cubre tres casos legítimos:
      //   • acceptRequest  → arrayUnion([request.auth.uid]) en el doc del remitente
      //   • removeFriend   → arrayRemove([request.auth.uid]) en el doc del ex-amigo
      //   • deleteAllUserFriendData → arrayRemove([request.auth.uid]) en cada amigo
      allow update: if request.auth != null && (
        request.auth.uid == userId
        ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
          && (
            // arrayUnion([request.auth.uid]): añadir propio UID (solo si aún no estaba)
            (
              request.resource.data.friends.hasAll(resource.data.get('friends', []))
              && request.resource.data.friends.size() == resource.data.get('friends', []).size() + 1
              && request.resource.data.friends.hasAll([request.auth.uid])
              && !resource.data.get('friends', []).hasAll([request.auth.uid])
            )
            ||
            // arrayRemove([request.auth.uid]): eliminar propio UID (solo si estaba)
            (
              resource.data.get('friends', []).hasAll(request.resource.data.friends)
              && request.resource.data.friends.size() == resource.data.get('friends', []).size() - 1
              && !request.resource.data.friends.hasAll([request.auth.uid])
              && resource.data.get('friends', []).hasAll([request.auth.uid])
            )
          )
        )
      );
      allow delete: if false;
    }

    // ─── Solicitudes de amistad ───────────────────────────
    match /friend_requests/{requestId} {
      // Solo el remitente o destinatario puede leer
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId);
      // Solo el remitente puede crear, con ID determinista senderId_receiverId.
      // El ID determinista hace que un segundo intento sea tratado como update
      // (rechazado por la regla de update), previniendo solicitudes duplicadas.
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && requestId == request.resource.data.senderId + '_' + request.resource.data.receiverId;
      // El destinatario puede aceptar/rechazar; el remitente puede actualizar para cancelar.
      // Solo se permiten cambios en 'status' y 'updatedAt'; los campos de identidad son inmutables.
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
      // Ambos pueden eliminar
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId);
    }

    // ─── Chats ──────────────────────────────────────────
    match /chats/{chatId} {
      // Solo los participantes pueden leer el chat
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Solo se puede crear un chat con un ID determinista: los dos UIDs de los
      // participantes ordenados lexicográficamente y unidos por "_".
      // Esto evita que dos clientes concurrentes creen documentos duplicados
      // para el mismo par de usuarios, ya que cualquier ID aleatorio será
      // rechazado por esta regla.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2
        && (
          chatId == request.resource.data.participants[0] + '_' + request.resource.data.participants[1]
          || chatId == request.resource.data.participants[1] + '_' + request.resource.data.participants[0]
        );

      // Solo los participantes pueden actualizar, y únicamente los campos de metadatos del chat
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['lastMessage', 'lastMessageTime', 'unreadCounts']);

      // Solo los participantes pueden eliminar el chat
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // ─── Mensajes (subcolección) ────────────────────
      match /messages/{messageId} {
        // Solo los participantes del chat padre pueden leer mensajes
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Solo un participante puede crear un mensaje, y debe ser el remitente
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000;

        // Solo se permite actualizar 'read' o 'reactions'
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'reactions']);

        // Solo los participantes pueden eliminar mensajes
        allow delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
