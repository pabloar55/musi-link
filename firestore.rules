rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Usuarios ───────────────────────────────────────
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer perfiles (necesario para búsqueda y avatares)
      allow read: if request.auth != null;
      // Solo el propio usuario puede crear/editar su perfil
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ─── Chats ──────────────────────────────────────────
    match /chats/{chatId} {
      // Solo los participantes pueden leer el chat
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Cualquier usuario autenticado puede crear un chat
      // (siempre que se incluya a sí mismo como participante)
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      // Solo los participantes pueden actualizar (ej: lastMessage)
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Solo los participantes pueden eliminar el chat
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // ─── Mensajes (subcolección) ────────────────────
      match /messages/{messageId} {
        // Solo los participantes del chat padre pueden leer mensajes
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Solo un participante puede crear un mensaje, y debe ser el remitente
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;

        // Solo se permite actualizar 'read' o 'reactions'
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'reactions']);

        // Solo los participantes pueden eliminar mensajes
        allow delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
